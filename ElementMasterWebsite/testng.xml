<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="false">
<listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="utils.RetryListener"/>    
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="UI Tests">

